# Public (SSR / site)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# CMS antiguo (Data/page, Administrativo, etc.) -> sí usa /api
NEXT_PUBLIC_API_BASE_URL=https://api-centralizador.apiworking.pe/api

# Catalog nuevo -> NO usa /api (va directo a /catalog/...)
NEXT_PUBLIC_CATALOG_BASE_URL=https://api-centralizador.apiworking.pe

# Server-only (proxies Next hacia centralizador)
CMS_REMOTE_BASE_URL=https://api-centralizador.apiworking.pe

# WhatsApp (temporal; luego puedes leerlo de /catalog/config/whatsapp)
NEXT_PUBLIC_WHATSAPP_PHONE=919688631